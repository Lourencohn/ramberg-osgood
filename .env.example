# Copie este arquivo para .env e preencha com os valores reais.
# Nunca versione o .env com credenciais reais.

# String de conexão do PostgreSQL.
#
# Formato local:
#   postgresql://usuario:senha@localhost:5432/ramberg_osgood
#
# Formato Neon (use a connection string do painel do Neon, com SSL):
#   postgresql://USUARIO:SENHA@HOST.neon.tech/NOME_DO_BANCO?sslmode=require
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.neon.tech/NOME_DO_BANCO?sslmode=require"
